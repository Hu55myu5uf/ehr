# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=ehr_system
DB_USER=root
DB_PASS=

# Application Settings
APP_NAME="EHR System"
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost/ehr
APP_KEY=base64:your-32-char-app-key-here-change-this

# JWT Configuration
JWT_SECRET=your-secret-key-change-this-in-production
JWT_EXPIRY=3600
JWT_REFRESH_EXPIRY=86400

# Encryption Keys (for SSN, sensitive data)
ENCRYPTION_KEY=your-encryption-key-32-chars-min
ENCRYPTION_METHOD=AES-256-CBC

# Session Configuration
SESSION_DRIVER=database
SESSION_LIFETIME=30
SESSION_TIMEOUT=1800

# Redis (Optional - for production)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# CORS Settings
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost

# Security Settings
BCRYPT_ROUNDS=12
MFA_ENABLED=false
PASSWORD_MIN_LENGTH=8

# Email Configuration (for notifications)
MAIL_DRIVER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=noreply@ehr.local
MAIL_FROM_NAME="EHR System"

# File Upload
MAX_UPLOAD_SIZE=10485760
ALLOWED_FILE_TYPES=pdf,jpg,jpeg,png

# Logging
LOG_LEVEL=debug
LOG_CHANNEL=daily

# FHIR Settings
FHIR_VERSION=R4
FHIR_BASE_URL=http://localhost/ehr/fhir

# Audit Settings
AUDIT_ENABLED=true
AUDIT_LOG_ALL_REQUESTS=true
